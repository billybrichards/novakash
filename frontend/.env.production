# VITE_API_URL intentionally omitted — let nginx proxy /api/ and /auth/ to the Hub.
# Setting this to an absolute URL causes cross-origin requests which can trigger
# subtle CORS/rendering failures. The nginx.conf proxies to 16.54.141.121:8091.
VITE_TIMESFM_WS_URL=ws://16.52.14.182:8080/ws/forecast
