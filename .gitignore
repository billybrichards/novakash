# ── Secrets (CRITICAL — never commit) ────────────────────────────────────
# Match .env, .env.local, .env.production, .env.*.local at any depth.
# If you add a new shell of secrets, add it here too.
.env
.env.*
**/.env
**/.env.*
!**/.env.example
!**/.env.template
.keys/
**/.keys/
*.pem
*.key
*.p12
*_rsa
*_ed25519
id_rsa*
id_ed25519*
__pycache__/
*.pyc
node_modules/
dist/
.vite/
*.egg-info/
.pytest_cache/
pgdata/
caddy_data/
caddy_config/
.worktrees/

# v11: large log archives (87MB+, keep locally only for post-mortem analysis)
docs/log_archive/
# Note: docs/truth_dataset/ IS committed — small CSVs, useful for ML/analysis
