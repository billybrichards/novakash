# ── Margin Engine Environment ──
# Deployed to: /opt/margin-engine/.env on AWS eu-west-2
# All vars are prefixed with MARGIN_ (Pydantic env_prefix)

# ── Binance 5x Cross-Margin ──
MARGIN_BINANCE_API_KEY=
MARGIN_BINANCE_API_SECRET=
MARGIN_PAPER_MODE=true

# ── Signal Source (TimesFM v3 composite WS) ──
MARGIN_TIMESFM_WS_URL=ws://3.98.114.0:8080/v3/signal
MARGIN_SIGNAL_THRESHOLD=0.3

# ── Position Sizing ──
MARGIN_STARTING_CAPITAL=500.0
MARGIN_LEVERAGE=5
MARGIN_BET_FRACTION=0.05

# ── Risk Management ──
MARGIN_MAX_OPEN_POSITIONS=3
MARGIN_MAX_EXPOSURE_PCT=0.60
MARGIN_DAILY_LOSS_LIMIT_PCT=0.10
MARGIN_CONSECUTIVE_LOSS_COOLDOWN=3
MARGIN_COOLDOWN_SECONDS=600
MARGIN_STOP_LOSS_PCT=0.015
MARGIN_TAKE_PROFIT_PCT=0.03
MARGIN_TRAILING_STOP_PCT=0.01
MARGIN_MAX_HOLD_SECONDS=3600
MARGIN_SIGNAL_REVERSAL_THRESHOLD=-0.2

# ── Timescales ──
MARGIN_TRADING_TIMESCALES=5m,15m,1h

# ── Database (Railway PostgreSQL) ──
MARGIN_DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/DB

# ── Telegram Alerts ──
MARGIN_TELEGRAM_BOT_TOKEN=
MARGIN_TELEGRAM_CHAT_ID=
MARGIN_TELEGRAM_ENABLED=true

# ── Status Server (for Hub proxy) ──
MARGIN_STATUS_PORT=8090

# ── Loop Cadence ──
MARGIN_TICK_INTERVAL_S=2.0
