# ── Margin Engine Environment ──
# Deployed to: /opt/margin-engine/.env on AWS eu-west-2
# All vars are prefixed with MARGIN_ (Pydantic env_prefix)

# ── Binance 5x Cross-Margin (Ed25519 key pair) ──
MARGIN_BINANCE_API_KEY=cBYrIKFmp3lXjw4nJ1V87PFBdEKHLwSbbPmEESUYLP4itd413pUZWD9Ax0pDN91f
MARGIN_BINANCE_PRIVATE_KEY_PATH=/opt/margin-engine/.keys/binance_ed25519.pem
MARGIN_PAPER_MODE=true

# ── Signal Source (TimesFM v3 composite WS) ──
MARGIN_TIMESFM_WS_URL=ws://3.98.114.0:8080/v3/signal
MARGIN_SIGNAL_THRESHOLD=0.3

# ── Position Sizing ──
MARGIN_STARTING_CAPITAL=1000.0
MARGIN_LEVERAGE=5
MARGIN_BET_FRACTION=0.05

# ── Risk Management ──
MARGIN_DAILY_LOSS_LIMIT_PCT=0.10
MARGIN_CONSECUTIVE_LOSS_COOLDOWN=3
MARGIN_COOLDOWN_SECONDS=600
MARGIN_STOP_LOSS_PCT=0.006
MARGIN_TAKE_PROFIT_PCT=0.005
MARGIN_TRAILING_STOP_PCT=0.003
MARGIN_MAX_HOLD_SECONDS=900

# ── V4 Fusion Settings ──
MARGIN_V4_SNAPSHOT_URL=http://3.98.114.0:8080
MARGIN_ENGINE_USE_V4_ACTIONS=true
MARGIN_V4_PRIMARY_TIMESCALE=5m
MARGIN_V4_TIMESCALES=5m,15m,1h,4h
MARGIN_V4_STRATEGY=fee_aware_15m
MARGIN_V4_POLL_INTERVAL_S=2.0
MARGIN_V4_FRESHNESS_S=10.0
MARGIN_V4_ENTRY_EDGE=0.10
MARGIN_V4_CONTINUATION_MIN_CONVICTION=0.10
MARGIN_V4_CONTINUATION_MAX=7
MARGIN_V4_MIN_EXPECTED_MOVE_BPS=15.0
MARGIN_V4_ALLOW_MEAN_REVERTING=false
MARGIN_V4_EVENT_EXIT_SECONDS=120
MARGIN_V4_MACRO_MODE=advisory
MARGIN_V4_MACRO_HARD_VETO_CONFIDENCE_FLOOR=80
MARGIN_V4_MACRO_ADVISORY_SIZE_MULT_ON_CONFLICT=0.75

# ── Database (Railway PostgreSQL) ──
MARGIN_DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/DB

# Note: V4 fusion uses MARGIN_V4_TIMESCALES (5m,15m,1h,4h) for multi-timescale consensus.
# MARGIN_TRADING_TIMESCALES is DEPRECATED (v2/v3 legacy) — not used in V4 path.

# ── Fee-aware continuation ──
MARGIN_FEE_AWARE_CONTINUATION_ENABLED=false
MARGIN_CONTINUATION_ALIGNMENT_ENABLED=false
MARGIN_CONTINUATION_MIN_TIMESCALES=2
MARGIN_CONTINUATION_HOLD_EXTENSION_MAX=2.0
MARGIN_MAX_PARTIAL_CLOSES=3
MARGIN_PARTIAL_CLOSE_COOLDOWN_S=300.0
MARGIN_FEE_AWARE_PARTIAL_TP_THRESHOLD=0.75
MARGIN_FEE_AWARE_PARTIAL_TP_SIZE=0.25

# ── Telegram Alerts ──
MARGIN_TELEGRAM_BOT_TOKEN=
MARGIN_TELEGRAM_CHAT_ID=
MARGIN_TELEGRAM_ENABLED=true

# ── Status Server (for Hub proxy) ──
MARGIN_STATUS_PORT=8090

# ── Loop Cadence ──
MARGIN_TICK_INTERVAL_S=2.0
