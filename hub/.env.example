# BTC-Trader Hub — runtime configuration (AWS Montreal deploy).
#
# On the Montreal EC2 box this file lives at /home/ubuntu/hub/.env and
# is templated by .github/workflows/deploy-hub.yml on every push to
# develop. Do NOT hand-edit on the host -- the next deploy will
# overwrite. Rotate secrets in the billybrichards/novakash Actions
# secrets and re-fire the workflow.

# ─── Database ────────────────────────────────────────────────────────
# Shared Railway Postgres. Same DATABASE_URL the macro-observer,
# data-collector, margin-engine, and engine services use. asyncpg
# driver prefix required (hub/db/database.py builds an async engine).
DATABASE_URL=postgresql+asyncpg://USER:PASS@hopper.proxy.rlwy.net:PORT/railway

# ─── JWT signing ────────────────────────────────────────────────────
# SECRET_KEY is the pydantic-settings field name in
# hub/db/database.py::Settings. The deploy workflow populates it from
# the JWT_SECRET Actions secret so the operator's mental model stays
# "JWT secret" while the hub reads it under its pydantic alias.
SECRET_KEY=changeme-in-production-please

# ─── Upstream service URLs ───────────────────────────────────────────
# TimesFM: local to the Montreal box once the hub lives there.
# On the Railway hub this was http://3.98.114.0:8080 -- the cross-region
# hop is the main reason DEP-02 is being done.
TIMESFM_URL=http://localhost:8080

# Margin engine: stays in eu-west-2. The deploy workflow builds this
# from the MARGIN_ENGINE_HOST Actions secret (the same secret
# deploy-margin-engine.yml reads), so rotating the IP only touches one
# place.
MARGIN_ENGINE_URL=http://MARGIN_ENGINE_HOST:8090

# ─── Trading approval gate ───────────────────────────────────────────
# Used by hub/api/trading_config.py::_verify_password for the
# config-approval flow. Optional: if empty, approval is permissive
# (dev mode). In prod you want this set.
TRADING_APPROVAL_PASSWORD=

# ─── Debug ───────────────────────────────────────────────────────────
# SQLAlchemy echo + verbose logging. Keep false in prod.
DEBUG=false

# ─── Vars NOT set on AWS ─────────────────────────────────────────────
# The following vars are only meaningful in the Railway hub and are
# intentionally absent here:
#
#   PORT                  -- Railway injects it. On AWS the uvicorn CMD
#                            in hub/Dockerfile.aws pins 8091.
#   RAILWAY_*             -- Railway platform vars. Never set on AWS.
#
# The following vars are read by hub/api/setup.py ONLY for display in
# the onboarding UI (not for actually calling the APIs -- that's the
# engine's job). Leave them unset on the AWS hub unless the operator
# wants the onboarding page to show them as "configured":
#
#   POLY_API_KEY, POLY_API_SECRET, POLY_API_PASSPHRASE
#   POLY_PRIVATE_KEY, POLY_FUNDER_ADDRESS
#   OPINION_API_KEY, OPINION_WALLET_KEY
#   BINANCE_API_KEY, BINANCE_API_SECRET
#   COINGLASS_API_KEY
#   POLYGON_RPC_URL
#   TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID
#   DOMAIN, PAPER_MODE, STARTING_BANKROLL
#
# The hub MUST NOT call Polymarket directly -- see docs/CI_CD.md and
# the DEP-02 PR body. Writing manual_trades rows is the hub's only
# role; the Montreal engine polls and executes.
