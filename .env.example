# ── Database ──
DB_USER=btctrader
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Hub Auth ──
ADMIN_USERNAME=billy
ADMIN_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ── Polymarket ──
POLY_PRIVATE_KEY=0x...
POLY_API_KEY=...
POLY_API_SECRET=...
POLY_API_PASSPHRASE=...
POLY_FUNDER_ADDRESS=0x...

# ── Opinion ──
OPINION_API_KEY=...
OPINION_WALLET_KEY=0x...

# ── Binance (data only) ──
BINANCE_API_KEY=...
BINANCE_API_SECRET=...

# ── CoinGlass ──
COINGLASS_API_KEY=...

# ── Polygon RPC ──
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Telegram ──
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── TG Narrative V2 (plans/serialized-drifting-clover.md) ──
# Flip to true to route alerts through the new pipeline (domain payloads →
# TelegramRenderer → TelegramSender). Default false = legacy path untouched.
TG_NARRATIVE_V2_ENABLED=false
# Comma-separated lowercase allowlist of user-owned EOAs (MetaMask, hot wallets).
# Wallet-delta classifier tags outflows to these as MANUAL_WITHDRAWAL (INFO tier)
# vs unknown destinations as UNEXPECTED (TACTICAL).
OWNER_EOA_ADDRESSES=

# ── Risk Settings ──
STARTING_BANKROLL=500
PAPER_MODE=true

# ── TimesFM v2.2 calibrated P(UP) consumption ──
# Related: novakash-timesfm PR #107 (forecaster-side isotonic calibration).
# When true (default), the engine prefers `probability_up_calibrated`
# returned by the forecaster and falls back to `probability_up` when the
# calibrated field is null (pre-PR-107 forecaster, ISOTONIC_CALIBRATION_ENABLED=false
# on the forecaster, or no calibrator artifact in S3 yet). Flip to false to
# force the engine onto the raw probability even when calibration is
# available upstream — this is the engine-side kill switch independent
# of the forecaster's ISOTONIC_CALIBRATION_ENABLED.
V2_PROB_USE_CALIBRATED=true

# ── Hub Service URLs (proxy to external services) ──
# NOTE: these MUST be set in production (Railway / AWS). If they fall through to
# localhost defaults the Hub proxy will return 502 "Cannot reach service" for
# every /api/v3/* and /api/margin/* request.
#   - TIMESFM_URL      → Montreal EC2 (ca-central-1), port 8080, /v3/snapshot etc.
#   - MARGIN_ENGINE_URL → eu-west-2 EC2, port 8090, /status etc.
# Current prod values are stored in Railway's Novakash → develop env variables.
MARGIN_ENGINE_URL=http://localhost:8090
TIMESFM_URL=http://localhost:8001

# ── Domain (for Caddy HTTPS) ──
DOMAIN=trader.yourdomain.com
