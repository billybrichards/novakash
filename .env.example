# ── Database ──
DB_USER=btctrader
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Hub Auth ──
ADMIN_USERNAME=billy
ADMIN_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# ── Polymarket ──
POLY_PRIVATE_KEY=0x...
POLY_API_KEY=...
POLY_API_SECRET=...
POLY_API_PASSPHRASE=...
POLY_FUNDER_ADDRESS=0x...

# ── Opinion ──
OPINION_API_KEY=...
OPINION_WALLET_KEY=0x...

# ── Binance (data only) ──
BINANCE_API_KEY=...
BINANCE_API_SECRET=...

# ── CoinGlass ──
COINGLASS_API_KEY=...

# ── Polygon RPC ──
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Telegram ──
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Risk Settings ──
STARTING_BANKROLL=500
PAPER_MODE=true

# ── Hub Service URLs (proxy to external services) ──
# NOTE: these MUST be set in production (Railway / AWS). If they fall through to
# localhost defaults the Hub proxy will return 502 "Cannot reach service" for
# every /api/v3/* and /api/margin/* request.
#   - TIMESFM_URL      → Montreal EC2 (ca-central-1), port 8080, /v3/snapshot etc.
#   - MARGIN_ENGINE_URL → eu-west-2 EC2, port 8090, /status etc.
# Current prod values are stored in Railway's Novakash → develop env variables.
MARGIN_ENGINE_URL=http://localhost:8090
TIMESFM_URL=http://localhost:8001

# ── Domain (for Caddy HTTPS) ──
DOMAIN=trader.yourdomain.com

# ── Dense multi-asset signal collection (shadow-only, task #165 / #166-170) ──
# Disabled by default. Set to true on Montreal after PR-4 soak passes.
DENSE_SIGNALS_ENABLED=false
DENSE_SIGNALS_ASSETS=BTC,ETH,SOL,XRP
DENSE_SIGNALS_TIMEFRAMES=5m,15m
